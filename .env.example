# Required
SERVICE_DID=did:web:validate.propdata.org.uk
SIGNING_KEY_HEX=<64-char-hex-ed25519-secret-key>

# Optional (defaults shown)
SIGNING_KEY_ID=validation-service-key
TIR_REGISTRY_URL=https://raw.githubusercontent.com/property-data-standards-co/tir/main/registry.json
TIR_CACHE_TTL_MS=3600000
DID_CACHE_TTL_MS=3600000
MAX_BODY_SIZE=1048576
LOG_LEVEL=info
PORT=8080
